int	sort_two_b(t_stack **ahead, t_stack **bhead)
{
	long long a_top;
	long long b_top;

	a_top = (*ahead)->num;
	b_top = (*bhead)->num;
	pb(ahead, bhead);
	if (a_top < b_top)
		sb(bhead);
	return (2);
}


int	sort_two_b(t_stack **ahead, t_stack **bhead, long long *b_table)
{
	long long a_top;

	a_top = (*ahead)->num;
	pb(ahead, bhead);
	if (a_top > b_table[1])
		sb(bhead);
	return (2);
}
















